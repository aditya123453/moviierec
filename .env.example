# ============================================================================
# CINEMAGIC - Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================================

# TMDB API Configuration (Required)
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# API Settings
API_TIMEOUT=5                    # Request timeout in seconds
CACHE_TTL=86400                  # Cache duration in seconds (24 hours)

# Application Settings
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
ENVIRONMENT=development          # development, staging, production

# Feature Flags
ENABLE_TRAILER=true              # Show trailer player
ENABLE_EXTERNAL_SEARCH=true      # Allow global TMDB search
ENABLE_COLLABORATIVE_FILTERING=false  # Future enhancement

# Streamlit Cloud Secrets
# Use .streamlit/secrets.toml in production instead of this file
# Example:
# [general]
# TMDB_API_KEY = "your_key"

# Database Configuration (Optional - for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/cinemagic
# DB_USER=cinemagic_user
# DB_PASSWORD=your_secure_password

# Sentry Error Tracking (Optional)
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/123456

# Monitoring & Analytics (Optional)
# DATADOG_API_KEY=your_datadog_key
# NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ============================================================================
# IMPORTANT SECURITY NOTES:
# ============================================================================
# 1. NEVER commit .env file to Git
# 2. Use .env.example as a template
# 3. On Streamlit Cloud, add secrets via the app's Secrets settings
# 4. On Docker, pass env vars: docker run -e TMDB_API_KEY="xxx" ...
# 5. Rotate API keys regularly
# 6. Use strong passwords for database connections
# ============================================================================
